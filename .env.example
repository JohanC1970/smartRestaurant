# Database
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT (generate a strong random secret, min 32 chars)
JWT_SECRET=your_jwt_secret_here

# Mail (Gmail SMTP)
# MAIL_HOST and MAIL_PORT have defaults (smtp.gmail.com:587), only override if needed
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=abcd efgh ijkl mnop   # App Password from Google (16 chars, no real password)

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret

# Admin user (created on first startup)
ADMIN_EMAIL=admin@yourrestaurant.com
ADMIN_PASSWORD=YourStrongPassword1!

# Chatbot
CHATBOT_API_KEY=your_chatbot_api_key
